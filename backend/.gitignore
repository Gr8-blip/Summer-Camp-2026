```gitignore
# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# =========================
# Django
# =========================
db.sqlite3
db.sqlite3-journal

# Collected static files (generated by collectstatic)
staticfiles/

# User uploaded media (optional - remove if you intentionally track it)
media/

# =========================
# Environment variables
# =========================
.env
.env.*
!.env.example

# =========================
# Logs
# =========================
*.log
logs/

# =========================
# IDEs
# =========================
.vscode/
.idea/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# Testing
# =========================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# =========================
# Type checking / linting
# =========================
.mypy_cache/
.ruff_cache/
.pyre/

# =========================
# Build / Packaging
# =========================
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# PyInstaller
# =========================
*.manifest
*.spec

# =========================
# Local secrets / certificates
# =========================
*.pem
*.key
*.crt

# =========================
# Node.js (if using Vite/React)
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite
dist/
```
